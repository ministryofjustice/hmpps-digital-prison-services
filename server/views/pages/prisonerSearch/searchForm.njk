{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/select/macro.njk" import govukSelect %}

<form class="prisoner-search__form" data-test="prisoner-search-form" novalidate>
  <div class="horizontal-form govuk-!-margin-bottom-3">
    {{ govukInput({
      id: "term",
      name: "term",
      value: formValues.term,
      errorMessage: errors | findError('term'),
      label: {
        text: "Enter name or prison number"
      },
      classes: 'govuk-!-width-full',
      attributes: {
        'data-test': 'prisoner-search-term'
      }
    }) }}

    {{ govukSelect({
      id: "location",
      name: "location",
      value: formValues.location,
      label: {
        text: "Select location"
      },
      items: locationOptions,
      attributes: {
        'data-test': 'prisoner-search-location'
      }
    }) }}

    {{ govukButton({
      text: "Search",
      type: "submit",
      preventDoubleClick: true
    }) }}
    <input type="hidden" name="feature" value={{ formValues.feature }} />
  </div>

  {{ govukDetails({
    summaryText: "View by alerts",
    classes: 'govuk-!-margin-bottom-0',
    open: formValues.alerts.length > 0,
    html: alertCheckboxes,
    attributes: {
      'data-test': 'prisoner-search-alerts-container'
    }
  }) }}
</form>
